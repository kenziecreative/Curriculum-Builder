{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "composite": true,
    "emitDeclarationOnly": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "vite-plugins/**/*.ts"]
}
